model ManualPaymentRequest {
  id               String        @id @default(uuid())
  bookingId        String
  amount           Decimal       @db.Decimal(10, 2)
  method           String        // Cash, UPI, Bank Transfer
  notes            String?
  status           RequestStatus @default(PENDING)
  requestedById    String
  approvedById     String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  booking          Booking       @relation(fields: [bookingId], references: [id])
  requestedBy      User          @relation("RequestedManualPayments", fields: [requestedById], references: [id])
  approvedBy       User?         @relation("ApprovedManualPayments", fields: [approvedById], references: [id])

  @@map("manual_payment_requests")
}

model PropertyRequest {
  id               String        @id @default(uuid())
  name             String
  location         String
  ownerEmail       String
  ownerPhone       String
  details          Json?
  status           RequestStatus @default(PENDING)
  reason           String?       @db.Text // Rejection reason
  requestedById    String
  referredById     String?
  approvedById     String?
  rejectedById     String?
  rejectedAt       DateTime?
  propertyId       String?       @unique // Link to created property after approval
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  requestedBy      User          @relation("PropertyRequester", fields: [requestedById], references: [id])
  referredBy       User?         @relation("PropertyReferrer", fields: [referredById], references: [id])
  approvedBy       User?         @relation("PropertyApprover", fields: [approvedById], references: [id])
  rejectedBy       User?         @relation("PropertyRejecter", fields: [rejectedById], references: [id])
  property         Property?     @relation(fields: [propertyId], references: [id])

  @@map("property_requests")
}
