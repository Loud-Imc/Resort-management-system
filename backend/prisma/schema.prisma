model Notification {
  id        String   @id @default(uuid())
  title     String
  message   String
  type      String   // e.g., 'BOOKING_CREATED', 'PAYMENT_SUCCESS', 'SYSTEM'
  isRead    Boolean  @default(false)
  data      Json?    // For storing related IDs like bookingId
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model GlobalSetting {
  id          String   @id @default(uuid())
  key         String   @unique
  value       Json
  description String?  @db.Text
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@map("global_settings")
}

model PropertySettlement {
  id              String           @id @default(uuid())
  propertyId      String
  bookingId       String           @unique
  grossAmount     Decimal          @db.Decimal(10, 2)
  platformFee     Decimal          @db.Decimal(10, 2)
  cpCommission    Decimal          @db.Decimal(10, 2)
  netPayout       Decimal          @db.Decimal(10, 2)
  status          SettlementStatus @default(CALCULATED)
  createdById     String?
  approvedById    String?
  payoutById      String?
  processedAt     DateTime?
  referenceId     String?
  method          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  property        Property         @relation(fields: [propertyId], references: [id])
  booking         Booking          @relation(fields: [bookingId], references: [id])
  createdBy       User?            @relation("SettlementCreator", fields: [createdById], references: [id])
  approvedBy      User?            @relation("SettlementApprover", fields: [approvedById], references: [id])
  payoutBy        User?            @relation("SettlementPayoutProcessor", fields: [payoutById], references: [id])

  @@map("property_settlements")
}

model CPRedemptionRequest {
  id              String           @id @default(uuid())
  cpId            String
  amount          Decimal          @db.Decimal(12, 2)
  status          RedemptionStatus @default(REQUESTED)
  referenceId     String?
  method          String?
  approverId      String?
  payoutById      String?
  reason          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  channelPartner  ChannelPartner   @relation(fields: [cpId], references: [id])
  approver        User?            @relation("RedemptionApprover", fields: [approverId], references: [id])
  payoutBy        User?            @relation("RedemptionPayoutProcessor", fields: [payoutById], references: [id])

  @@map("cp_redemption_requests")
}

model FinancialAdjustmentRequest {
  id              String           @id @default(uuid())
  amount          Decimal          @db.Decimal(12, 2)
  type            AdjustmentType
  targetId        String           // CP or Guest userId
  reason          String
  requestedById   String
  approvedById    String?
  status          RequestStatus    @default(PENDING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  requestedBy     User             @relation("AdjustmentRequester", fields: [requestedById], references: [id])
  approvedBy      User?            @relation("AdjustmentApprover", fields: [approvedById], references: [id])

  @@map("financial_adjustment_requests")
}

model PaymentReconciliation {
  id              String           @id @default(uuid())
  paymentId       String           @unique
  gatewayStatus   String
  dbStatus        String
  status          RequestStatus    @default(PENDING)
  reconciledById  String?
  resolvedById    String?
  notes           String?          @db.Text
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  payment         Payment          @relation(fields: [paymentId], references: [id])
  reconciledBy    User?            @relation("ReconciliationMaker", fields: [reconciledById], references: [id])
  resolvedBy      User?            @relation("ReconciliationChecker", fields: [resolvedById], references: [id])

  @@map("payment_reconciliations")
}

model RefundRequest {
