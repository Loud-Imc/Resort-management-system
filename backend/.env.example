# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/resort_management?schema=public&sslmode=disable"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRATION="7d"

# Razorpay Configuration
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"

# Application
PORT=3000
NODE_ENV="development"

# Frontend URLs (for CORS)
ADMIN_URL="http://localhost:5173"
PUBLIC_URL="http://localhost:5174"

# Email (Optional - for booking confirmations)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASSWORD="your-app-password"
EMAIL_FROM="Resort Management <noreply@resort.com>"

# Messaging (Twilio or MSG91)
SMS_PROVIDER="TWILIO" # Change to "MSG91" to use MSG91
MSG91_AUTH_KEY="your_msg91_auth_key"
MSG91_OTP_TEMPLATE_ID="your_otp_template_id"
MSG91_WHATSAPP_SENDER="your_whatsapp_sender_number" # e.g. 919876543210

# MSG91 WhatsApp Master Templates (Template Names)
MSG91_TPL_GUEST_STAY="guest_stay"
MSG91_TPL_GUEST_BOOKING="guest_booking_status"
MSG91_TPL_PROP_BOOKING="property_alert"
MSG91_TPL_PARTNER_ALERTS="cp_messages"
MSG91_TPL_ACTION_LINKS="actions_links"
